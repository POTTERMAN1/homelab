import json
import logging
import sys

from fastapi import FastAPI, Request

logging.basicConfig(
    stream=sys.stdout,
    level=logging.DEBUG,
    format="%(asctime)s [%(levelname)s] %(message)s",
)
logger = logging.getLogger("seafile-webhook")

app = FastAPI()


@app.post("/webhook")
async def receive_webhook(request: Request) -> dict:
    headers = dict(request.headers)
    logger.info("INCOMING WEBHOOK")
    logger.info("Headers:\n%s", json.dumps(headers, indent=2))

    raw_body = await request.body()
    logger.info("Raw body:\n%s", raw_body.decode("utf-8", errors="replace"))

    try:
        payload = await request.json()
        logger.info("Parsed JSON:\n%s", json.dumps(payload, indent=2))
    except Exception as exc:  # noqa: BLE001
        logger.warning("Body is not valid JSON: %s", exc)

    logger.info("END")
    return {"status": "ok"}


@app.get("/health")
async def health() -> dict:
    return {"status": "ok"}
