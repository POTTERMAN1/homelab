services:
  homepage:
    container_name: homepage
    image: "{{ app_services.homepage.image }}:{{ app_services.homepage.version }}"
    restart: unless-stopped
    ports:
      - "3005:3000"
    volumes:
      - "{{ app_services.homepage.root_path }}/config:/app/config"
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      PUID: "1000"
      PGID: "1000"
      HOMEPAGE_ALLOWED_HOSTS: "home.potterman.party,localhost,127.0.0.1"
