const http = require('http');
const options = {
    host: 'localhost',
    port: 30000,
    timeout: 10
};

const healthcheck = http.request(options, (res) => {
    console.log(`HEALTHCHECK STATUS: ${res.statusCode}`);
    if (res.statusCode >= 200 && res.statusCode < 400) {
        process.exit(0);
    }
    else {
        process.exit(1);
    }
});

healthcheck.on('error', function (err) {
    console.error('ERROR');
    process.exit(1);
});

healthcheck.end();