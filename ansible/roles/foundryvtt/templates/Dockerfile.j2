FROM node:22-slim
# unzip install to unpack FoundryVTT during image build
RUN apt-get update && apt-get install -y --no-install-recommends unzip \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
# FOUNDRY_VERSION is passed from Ansible's .yml file through docker-compose
# This allows me to pin the image to a specific version for updates
ARG FOUNDRY_VERSION 
COPY FoundryVTT-Node-${FOUNDRY_VERSION}.zip .
COPY healthcheck.js /healthcheck.js
RUN unzip FoundryVTT-Node-${FOUNDRY_VERSION}.zip \
    && rm FoundryVTT-Node-${FOUNDRY_VERSION}.zip
EXPOSE 30000
HEALTHCHECK --interval=10s --timeout=10s --start-period=30s --retries=3 \
    CMD node /healthcheck.js
CMD ["node", "main.js", "--dataPath=/foundry_user_data"]
