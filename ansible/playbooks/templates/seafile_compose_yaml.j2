services:
  db:
    image: mariadb:10.11
    container_name: seafile-mysql
    restart: unless-stopped
    environment:
      - "MYSQL_ROOT_PASSWORD={{ vault_seafile_db_password }}"
      - MYSQL_LOG_CONSOLE=true
      - MARIADB_AUTO_UPGRADE=1
    volumes:
      - ./mariadb:/var/lib/mysql
    networks:
      - seafile_net

  memcached:
    image: memcached:1.6
    container_name: seafile-memcached
    restart: unless-stopped
    entrypoint: memcached -m 256
    networks:
      - seafile_net

  seafile:
    image: seafileltd/seafile-mc:latest
    container_name: seafile
    restart: unless-stopped
    ports:
      - "8060:80"
    volumes:
      - ./seafile-data:/shared # Data storage
    environment:
      - DB_HOST=db
      - "DB_ROOT_PASSWD={{ vault_seafile_db_password }}"
      - TIME_ZONE=Europe/Warsaw
      - SEAFILE_ADMIN_EMAIL=admin@potterman.party
      - "SEAFILE_ADMIN_PASSWORD={{ vault_seafile_db_password }}" # Temp admin pass
      - SEAFILE_SERVER_LETSENCRYPT=false # Caddy handles SSL
      - SEAFILE_SERVER_HOSTNAME=seafile.potterman.party
    depends_on:
      - db
      - memcached
    networks:
      - seafile_net

networks:
  seafile_net:
